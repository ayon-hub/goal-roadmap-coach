{
  "name": "goal-roadmap-coach",
  "version": "1.0.0",
  "description": "Goal planning coach with guided steps, deterministic scoring, and optional Ollama-backed generation.",
  "private": true,
  "main": "server.js",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "PLANNING_PROVIDER=mock SUGGESTION_PROVIDER=mock RESULT_PROVIDER=mock node server.js",
    "start:mock": "PLANNING_PROVIDER=mock SUGGESTION_PROVIDER=mock RESULT_PROVIDER=mock node server.js",
    "start:ollama": "bash scripts/run-ollama.sh",
    "test": "node test/run-tests.js"
  },
  "keywords": [
    "express",
    "goal-planning",
    "ollama",
    "vanilla-js"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2"
  }
}
