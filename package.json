{
  "name": "goal-roadmap-coach",
  "version": "1.0.0",
  "description": "Goal planning coach with guided steps, deterministic scoring, and optional Ollama-backed generation.",
  "private": true,
  "main": "server.js",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "start": "node backend/server.js",
    "dev": "PLANNING_PROVIDER=mock SUGGESTION_PROVIDER=mock RESULT_PROVIDER=mock node backend/server.js",
    "start:mock": "PLANNING_PROVIDER=mock SUGGESTION_PROVIDER=mock RESULT_PROVIDER=mock node backend/server.js",
    "start:ollama": "bash scripts/run-ollama.sh",
    "frontend:preview": "node frontend/tools/preview-static.js",
    "backend:start": "node backend/server.js",
    "backend:test": "node backend/test/run-tests.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node backend/test/run-tests.js",
    "coverage": "c8 --reporter=text --reporter=lcov --reporter=html node backend/test/run-tests.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "express",
    "goal-planning",
    "ollama",
    "vanilla-js"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^12.1.4",
    "@commitlint/config-conventional": "^12.1.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.12",
    "c8": "^7.12.0",
    "eslint": "^7.32.0",
    "husky": "^4.3.8",
    "lint-staged": "^10.5.4",
    "prettier": "^2.8.8",
    "typescript": "^4.4.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
