{
  "root": true,
  "env": {
    "es6": true
  },
  "extends": ["eslint:recommended"],
  "ignorePatterns": ["node_modules/", "coverage/", "frontend/public/images/"],
  "overrides": [
    {
      "files": [
        "server.js",
        "backend/**/*.js",
        "shared/**/*.js",
        "scripts/**/*.js",
        "commitlint.config.js"
      ],
      "env": {
        "node": true,
        "commonjs": true
      },
      "parserOptions": {
        "ecmaVersion": 2020
      },
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["frontend/public/**/*.js"],
      "env": {
        "browser": true,
        "es6": true
      },
      "parserOptions": {
        "ecmaVersion": 2020,
        "sourceType": "script"
      },
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["frontend/tools/**/*.js"],
      "env": {
        "node": true,
        "commonjs": true
      },
      "parserOptions": {
        "ecmaVersion": 2020
      },
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
